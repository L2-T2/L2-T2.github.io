<%
  function normalizeCollection(collection) {
    if (!collection) return [];
    if (Array.isArray(collection)) return collection;
    if (Array.isArray(collection.data)) return collection.data;
    return [];
  }

  function summaryFor(post) {
    const source = post.description || post.subtitle || post.excerpt || post.more || post.content || "";
    const cleaned = strip_html(source).replace(/\s+/g, " ").trim();
    if (!cleaned) return "";
    return cleaned.length > 180 ? `${cleaned.slice(0, 177)}...` : cleaned;
  }

  function sectionLabel(section) {
    return {
      "learning-journals": __("sections.learning_journals"),
      essay: __("sections.essays"),
      project: __("sections.projects"),
      "technical-notes": __("sections.technical_notes")
    }[section] || page.title || __("sections.section");
  }

  const section = page.section;
  const currentLanguage = page_language(page);
  const posts = site.posts
    .filter((post) => page_language(post) === currentLanguage
      && normalizeCollection(post.categories).some((category) => category.name === section))
    .sort("-date");

  const tags = new Map();
  posts.forEach((post) => {
    normalizeCollection(post.tags).forEach((tag) => {
      if (tag.name.toLowerCase() === section) return;
      tags.set(tag.name, { count: (tags.get(tag.name)?.count || 0) + 1, tag });
    });
  });

  const topTags = Array.from(tags.entries())
    .sort((a, b) => b[1].count - a[1].count || a[0].localeCompare(b[0]))
    .slice(0, 8);
%>
<section class="section-page">
  <div class="hero-panel panel">
    <div class="hero-kicker"><%= __("sections.section") %></div>
    <h1 class="hero-title"><%= sectionLabel(section) %></h1>
    <% if (page.content && page.content.trim()) { %>
    <div class="hero-summary prose">
      <%- page.content %>
    </div>
    <% } %>
    <div class="hero-metrics">
      <div class="metric-card">
        <div class="metric-value"><%= posts.length %></div>
        <div class="metric-label"><%= __("section.entries") %></div>
      </div>
      <div class="metric-card">
        <div class="metric-value"><%= topTags.length %></div>
        <div class="metric-label"><%= __("section.top_tags") %></div>
      </div>
      <div class="metric-card">
        <div class="metric-value"><%= posts.length ? date(posts.first().date, "YYYY") : "--" %></div>
        <div class="metric-label"><%= __("section.latest_year") %></div>
      </div>
    </div>
  </div>

  <% if (topTags.length) { %>
  <div class="taxonomy-strip panel">
    <h2 class="taxonomy-strip-title"><%= __("section.common_tags") %></h2>
    <div class="taxonomy-list">
      <% topTags.forEach(([name, data]) => { %>
      <a class="taxonomy-link" href="<%- localized_tag_url(data.tag, currentLanguage) %>">#<%= name %> · <%= data.count %></a>
      <% }) %>
    </div>
  </div>
  <% } %>

  <% if (posts.length) { %>
  <div class="card-grid">
    <% posts.forEach((post) => { %>
    <article class="entry-card panel">
      <div class="entry-card-header">
        <span class="entry-date"><%= date(post.date, "YYYY-MM-DD") %></span>
        <% if (section === "project" && post.status) { %>
        <span class="entry-status"><%= post.status %></span>
        <% } %>
      </div>

      <a class="entry-title-link" href="<%- url_for(post.path) %>">
        <h2 class="entry-title"><%= post.title %></h2>
      </a>

      <% const summary = summaryFor(post); %>
      <% if (summary) { %>
      <p class="entry-description"><%= summary %></p>
      <% } %>

      <div class="entry-meta-row">
        <% if (post.course) { %>
        <span class="meta-chip"><%= post.course %></span>
        <% } %>
        <% normalizeCollection(post.tags).forEach((tag) => { %>
        <a class="meta-chip" href="<%- localized_tag_url(tag, currentLanguage) %>">#<%= tag.name %></a>
        <% }) %>
      </div>

      <div class="entry-card-footer">
        <a class="entry-action" href="<%- url_for(post.path) %>"><%= __("section.open_entry") %></a>
        <% if (post.repo) { %>
        <a class="entry-external" href="<%= post.repo %>" target="_blank" rel="noopener"><%= __("section.repository") %></a>
        <% } %>
      </div>
    </article>
    <% }) %>
  </div>
  <% } else { %>
  <div class="empty-panel panel">
    <%= __("section.empty") %>
  </div>
  <% } %>
</section>
