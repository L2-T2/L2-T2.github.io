<%
  function normalizeCollection(collection) {
    if (!collection) return [];
    if (Array.isArray(collection)) return collection;
    if (Array.isArray(collection.data)) return collection.data;
    return [];
  }

  function escapeHtml(value) {
    return String(value || "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function escapeRegExp(value) {
    return String(value || "").replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
  }

  function sectionLabel(section) {
    return {
      "learning-journals": __("sections.learning_journals"),
      essay: __("sections.essay"),
      project: __("sections.project"),
      "technical-notes": __("sections.technical_notes")
    }[section] || __("sections.section");
  }

  function readingMinutes(html) {
    const text = strip_html(html || "").replace(/\s+/g, " ").trim();
    const westernWords = text.match(/[A-Za-z0-9_]+/g) || [];
    const cjkChars = text.match(/[\u3400-\u9FFF]/g) || [];
    const units = westernWords.length + Math.ceil(cjkChars.length / 2);
    return Math.max(1, Math.ceil(units / 260));
  }

  const categories = normalizeCollection(page.categories);
  const tags = normalizeCollection(page.tags);
  const currentLanguage = page_language(page);
  const section = categories[0] ? categories[0].name : "learning-journals";
  const sectionPath = localized_url(`/${section}/`, currentLanguage);

  const siblings = site.posts
    .filter((post) => page_language(post) === currentLanguage
      && normalizeCollection(post.categories).some((category) => category.name === section))
    .sort("-date")
    .toArray();

  const currentIndex = siblings.findIndex((post) => post.path === page.path);
  const newer = currentIndex > 0 ? siblings[currentIndex - 1] : null;
  const older = currentIndex >= 0 && currentIndex < siblings.length - 1 ? siblings[currentIndex + 1] : null;
  const isEssay = section === "essay";

  function buildTocItems(html) {
    const items = [];
    const headingPattern = /<h([2-4]) id="([^"]+)">([\s\S]*?)<\/h\1>/g;
    let match;

    while ((match = headingPattern.exec(html)) !== null) {
      items.push({
        level: Number(match[1]),
        id: match[2],
        title: strip_html(match[3]).replace(/\s+/g, " ").trim()
      });
    }

    return items;
  }

  function extractEssayNotes(html) {
    const notes = [];
    const contentWithoutNotes = html.replace(
      /<blockquote>\s*<p>\[!NOTE\|([^|\]]+)\|#([^\]]+)\]\s*<\/p>\s*(?:<\/blockquote>\s*<blockquote>\s*)?([\s\S]*?)\s*<\/blockquote>/g,
      (_, title, anchor, body) => {
        const cleanBody = String(body || "").trim();
        if (!strip_html(cleanBody).replace(/\s+/g, " ").trim()) return "";

        const index = notes.length + 1;
        const placeholder = `<!--essay-note-placeholder-${index}-->`;
        notes.push({
          index,
          title: title.trim(),
          anchor: anchor.trim(),
          body: cleanBody,
          placeholder
        });
        return placeholder;
      }
    );

    let contentWithMarkers = contentWithoutNotes;
    notes.forEach((note) => {
      const marker = `<sup class="essay-note-marker" id="essay-note-ref-${note.index}" data-note-index="${note.index}"><a href="#essay-note-${note.index}" aria-label="${escapeHtml(__("entry.annotation_open"))} ${note.index}">${note.index}</a></sup>`;
      const targetPattern = new RegExp(`(<([a-zA-Z0-9]+)([^>]*)\\sid="${escapeRegExp(note.anchor)}"([^>]*)>[\\s\\S]*?<\\/\\2>)`);

      if (targetPattern.test(contentWithMarkers)) {
        contentWithMarkers = contentWithMarkers.replace(targetPattern, `$1${marker}`);
        contentWithMarkers = contentWithMarkers.replace(note.placeholder, "");
      } else {
        contentWithMarkers = contentWithMarkers.replace(note.placeholder, marker);
      }
    });

    return {
      content: contentWithMarkers,
      notes
    };
  }

  function slugifyText(value) {
    const base = strip_html(String(value || ""))
      .toLowerCase()
      .replace(/[^\w一-鿿]+/g, "-")
      .replace(/^-+|-+$/g, "");
    return base || "section";
  }

  function envKindSlug(kind) {
    const k = String(kind || "").toLowerCase().trim();
    const known = ["statement", "definition", "theorem", "lemma", "proposition", "corollary", "proof", "remark", "intuition", "example", "construction"];
    for (let i = 0; i < known.length; i += 1) {
      if (k.indexOf(known[i]) === 0) return known[i];
    }
    const chineseKinds = {
      "陈述": "statement",
      "定义": "definition",
      "定理": "theorem",
      "引理": "lemma",
      "命题": "proposition",
      "推论": "corollary",
      "证明": "proof",
      "备注": "remark",
      "注记": "remark",
      "直觉": "intuition",
      "例子": "example",
      "示例": "example",
      "构造": "construction"
    };
    for (const [label, slug] of Object.entries(chineseKinds)) {
      if (k.startsWith(label)) return slug;
    }
    return "note";
  }

  // Turn the authored "---[Kind: Title] ... ---[end]" blocks (which Pandoc
  // renders as literal <p>-[Kind: Title]</p> paragraphs) into labelled
  // theorem/proof/definition environments, and collect them for the sidebar.
  function renderMathEnvironments(html) {
    const items = [];
    const used = Object.create(null);
    const blockPattern = /<p>\s*[—–-]+\s*\[\s*([^:\]]+?)\s*:\s*([^\]]*?)\s*\]\s*<\/p>([\s\S]*?)<p>\s*[—–-]+\s*\[\s*end\s*\]\s*<\/p>/g;

    const content = html.replace(blockPattern, (match, kind, title, inner) => {
      const slug = envKindSlug(kind);
      const cleanKind = strip_html(kind).replace(/\s+/g, " ").trim();
      const cleanTitle = strip_html(title).replace(/\s+/g, " ").trim();
      let id = slugifyText(cleanTitle || cleanKind);
      if (used[id]) {
        let n = 2;
        while (used[`${id}-${n}`]) n += 1;
        id = `${id}-${n}`;
      }
      used[id] = true;
      items.push({ id, kind: cleanKind, slug, title: cleanTitle });

      const titleMarkup = cleanTitle ? `<span class="mj-env-title">${escapeHtml(cleanTitle)}</span>` : "";
      return `<section class="mj-env mj-env-${slug}" id="${id}">`
        + `<div class="mj-env-head"><span class="mj-env-kind">${escapeHtml(cleanKind)}</span>${titleMarkup}</div>`
        + `<div class="mj-env-body">${inner}</div>`
        + `</section>`;
    });

    return { content, items };
  }

  const isMathDoc = !isEssay && section === "learning-journals";
  const mathDoc = isMathDoc ? renderMathEnvironments(page.content) : null;

  const tocItems = isEssay ? buildTocItems(page.content) : [];
  const essayContent = isEssay ? extractEssayNotes(page.content) : { content: page.content, notes: [] };
  const mathTocItems = mathDoc ? mathDoc.items : [];
  const renderedContent = isEssay
    ? essayContent.content
    : (mathDoc ? mathDoc.content : page.content);
  const essayNotes = essayContent.notes;
  const readTime = readingMinutes(renderedContent);
%>
<article class="entry-page<% if (isEssay) { %> entry-page-essay<% } else if (isMathDoc) { %> entry-page-math<% } %>">
  <header class="entry-hero<% if (isEssay) { %> entry-doc-hero<% } else { %> panel<% } %>">
    <a class="entry-back" href="<%- sectionPath %>">&larr; <%= __("entry.back_to") %> <%= sectionLabel(section) %></a>
    <div class="hero-kicker"><%= sectionLabel(section) %></div>
    <h1 class="entry-hero-title"><%= page.title %></h1>
    <% if (page.description || page.subtitle) { %>
    <p class="entry-hero-summary"><%= page.description || page.subtitle %></p>
    <% } %>
    <% if (isEssay) { %>
    <dl class="entry-meta-list">
      <div>
        <dt><%= __("entry.date") %></dt>
        <dd><%= date(page.date, "YYYY-MM-DD") %></dd>
      </div>
      <div>
        <dt><%= __("entry.mode") %></dt>
        <dd><%= __("entry.explanation") %></dd>
      </div>
      <div>
        <dt><%= __("entry.length") %></dt>
        <dd><%= readTime %> <%= __("entry.min_read") %></dd>
      </div>
      <% if (page.byline) { %>
      <div>
        <dt><%= __("entry.byline") %></dt>
        <dd><%= page.byline %></dd>
      </div>
      <% } %>
    </dl>
    <% } else { %>
    <div class="entry-info-grid">
      <div class="entry-info-card">
        <span class="entry-info-label"><%= __("entry.date") %></span>
        <span class="entry-info-value"><%= date(page.date, "YYYY-MM-DD") %></span>
      </div>
      <div class="entry-info-card">
        <span class="entry-info-label"><%= __("entry.category") %></span>
        <span class="entry-info-value"><%= sectionLabel(section) %></span>
      </div>
      <% if (page.course) { %>
      <div class="entry-info-card">
        <span class="entry-info-label"><%= __("entry.course") %></span>
        <span class="entry-info-value"><%= page.course %></span>
      </div>
      <% } %>
      <% if (page.status) { %>
      <div class="entry-info-card">
        <span class="entry-info-label"><%= __("entry.status") %></span>
        <span class="entry-info-value"><%= page.status %></span>
      </div>
      <% } %>
      <% if (page.repo) { %>
      <div class="entry-info-card">
        <span class="entry-info-label"><%= __("entry.repository") %></span>
        <span class="entry-info-value"><a href="<%= page.repo %>" target="_blank" rel="noopener"><%= __("entry.open_link") %></a></span>
      </div>
      <% } %>
    </div>
    <% } %>
    <% if (tags.length) { %>
    <div class="taxonomy-list" style="margin-top: 1rem;">
      <% tags.forEach((tag) => { %>
      <a class="taxonomy-link" href="<%- localized_tag_url(tag, currentLanguage) %>">#<%= tag.name %></a>
      <% }) %>
    </div>
    <% } %>
  </header>

  <section class="entry-reading-layout<% if (isEssay) { %> entry-reading-layout-essay<% } else if (isMathDoc) { %> entry-reading-layout-math<% } %>">
    <% if (isEssay && tocItems.length) { %>
    <aside class="entry-toc">
      <div class="entry-toc-kicker"><%= __("toc.essay_kicker") %></div>
      <div class="entry-toc-title"><%= __("toc.essay_title") %></div>
      <nav class="entry-toc-nav" aria-label="<%= __('toc.essay_aria') %>">
        <ol class="entry-toc-list">
          <% tocItems.forEach((item) => { %>
          <li class="entry-toc-item entry-toc-level-<%= item.level %>">
            <a class="entry-toc-link" data-toc-link href="#<%= item.id %>"><%= item.title %></a>
          </li>
          <% }) %>
        </ol>
      </nav>
    </aside>
    <% } %>

    <% if (isMathDoc && mathTocItems.length) { %>
    <aside class="entry-toc entry-toc-math">
      <div class="entry-toc-kicker"><%= __("toc.page_kicker") %></div>
      <div class="entry-toc-title"><%= __("toc.page_title") %></div>
      <nav class="entry-toc-nav" aria-label="<%= __('toc.page_aria') %>">
        <ol class="entry-toc-list">
          <% mathTocItems.forEach((item) => { %>
          <li class="entry-toc-item mj-toc-item mj-toc-<%= item.slug %>">
            <a class="entry-toc-link mj-toc-link" data-toc-link href="#<%= item.id %>">
              <span class="mj-toc-kind"><%= item.kind %></span>
              <span class="mj-toc-text"><%= item.title || item.kind %></span>
            </a>
          </li>
          <% }) %>
        </ol>
      </nav>
    </aside>
    <% } %>

    <section class="entry-body panel<% if (isEssay) { %> entry-body-essay<% } else if (isMathDoc) { %> entry-body-math<% } %>">
      <div class="prose<% if (isEssay) { %> prose-essay<% } else if (isMathDoc) { %> prose-math<% } %>">
        <%- renderedContent %>
      </div>
    </section>

    <% if (isEssay && essayNotes.length) { %>
    <aside class="entry-annotations" aria-label="<%= __('entry.annotation_open') %>" data-annotation-rail>
      <% essayNotes.forEach((note) => { %>
      <section class="essay-annotation" id="essay-note-<%= note.index %>" data-note-index="<%= note.index %>">
        <div class="essay-annotation-head">
          <a class="essay-annotation-index" href="#essay-note-ref-<%= note.index %>" aria-label="<%= __('entry.annotation_back') %>"><%= note.index %></a>
          <div class="essay-annotation-title"><%= note.title %></div>
        </div>
        <div class="essay-annotation-body"><%- note.body %></div>
      </section>
      <% }) %>
    </aside>
    <% } %>
  </section>

  <% if (newer || older) { %>
  <nav class="entry-navigation<% if (isEssay) { %> entry-navigation-doc<% } %>">
    <% if (newer) { %>
    <a class="entry-nav-card panel" href="<%- url_for(newer.path) %>">
      <span class="entry-nav-label"><%= __("entry.newer") %></span>
      <span class="entry-nav-title"><%= newer.title %></span>
    </a>
    <% } else { %>
    <div></div>
    <% } %>

    <% if (older) { %>
    <a class="entry-nav-card panel" href="<%- url_for(older.path) %>">
      <span class="entry-nav-label"><%= __("entry.older") %></span>
      <span class="entry-nav-title"><%= older.title %></span>
    </a>
    <% } else { %>
    <div></div>
    <% } %>
  </nav>
  <% } %>
</article>
