<%
  const currentLanguage = page_language(page);
  const targetLanguage = currentLanguage === "zh" ? "en" : "zh-CN";
  const currentPath = `/${(page.path || "").replace(/^\/+|\/+$/g, "")}/`
    .replace(/^\/zh(?=\/)/, "")
    .replace(/\/index\.html\/$/, "/");
  const links = [
    [__("nav.home"), "/"],
    [__("nav.learning_journals"), "/learning-journals/"],
    [__("nav.essay"), "/essay/"],
    [__("nav.project"), "/project/"],
    [__("nav.technical_notes"), "/technical-notes/"],
    [__("nav.archive"), "/archives/"],
    [__("nav.about"), "/about/"]
  ];

  function isActive(target) {
    const normalized = `${target}`.replace(/\/?$/, "/");
    if (normalized === "/") return false;
    return currentPath === normalized || currentPath.startsWith(normalized);
  }
%>
<header class="site-header">
  <nav class="site-nav" aria-label="<%= __('nav.aria') %>">
    <a class="site-brand" href="<%- localized_url('/', currentLanguage) %>">
      <span class="site-brand-title"><%= config.title %></span>
      <span class="site-brand-tagline"><%= __("nav.tagline") %></span>
    </a>

    <div class="site-nav-links" data-nav-links>
      <% links.forEach(([label, href]) => { %>
      <a class="site-nav-link<% if (isActive(href)) { %> is-active<% } %>" href="<%- localized_url(href, currentLanguage) %>">
        <%= label %>
      </a>
      <% }); %>
    </div>

    <div class="site-nav-actions">
      <a
        class="site-language-switch"
        href="<%- language_switch_url(targetLanguage) %>"
        lang="<%= targetLanguage %>"
        hreflang="<%= targetLanguage %>"
        aria-label="<%= __('language.switch_aria') %>"
        title="<%= __('language.switch_aria') %>"
      >
        <span class="site-language-icon" aria-hidden="true"><%= currentLanguage === "zh" ? "A" : "文" %></span>
        <span><%= __("language.switch_label") %></span>
      </a>

      <button class="site-nav-toggle" type="button" aria-expanded="false" data-nav-toggle>
        <%= __("nav.menu") %>
      </button>
    </div>
  </nav>
</header>
