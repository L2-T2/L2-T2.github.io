<%
  const posts = site.posts.sort("-date");
%>
<section class="archive-page">
  <div class="hero-panel panel">
    <div class="hero-kicker">archive</div>
    <h1 class="hero-title">Archive</h1>
    <p class="hero-summary">A chronological overview of all published entries across notes, essays, projects, and code.</p>
  </div>

  <div class="card-grid">
    <% posts.forEach((post) => { %>
    <article class="entry-card panel">
      <div class="entry-card-header">
        <span class="entry-date"><%= date(post.date, "YYYY-MM-DD") %></span>
      </div>
      <a class="entry-title-link" href="<%- url_for(post.path) %>">
        <h2 class="entry-title"><%= post.title %></h2>
      </a>
      <p class="entry-description"><%= post.description || post.subtitle || strip_html(post.excerpt || post.content).slice(0, 180) %></p>
      <div class="entry-meta-row">
        <% if (post.categories && post.categories.data.length) { %>
        <span class="meta-chip"><%= post.categories.data[0].name %></span>
        <% } %>
      </div>
      <div class="entry-card-footer">
        <a class="entry-action" href="<%- url_for(post.path) %>">Open entry</a>
      </div>
    </article>
    <% }) %>
  </div>
</section>
