<%
  const currentLanguage = page_language(page);
  const posts = site.posts.filter((post) => page_language(post) === currentLanguage).sort("-date");

  function sectionLabel(section) {
    return {
      "learning-journals": __("sections.learning_journals"),
      essay: __("sections.essay"),
      project: __("sections.project"),
      "technical-notes": __("sections.technical_notes")
    }[section] || section;
  }
%>
<section class="archive-page">
  <div class="hero-panel panel">
    <div class="hero-kicker"><%= __("archive.kicker") %></div>
    <h1 class="hero-title"><%= __("archive.title") %></h1>
    <p class="hero-summary"><%= __("archive.summary") %></p>
  </div>

  <div class="card-grid">
    <% posts.forEach((post) => { %>
    <article class="entry-card panel">
      <div class="entry-card-header">
        <span class="entry-date"><%= date(post.date, "YYYY-MM-DD") %></span>
      </div>
      <a class="entry-title-link" href="<%- url_for(post.path) %>">
        <h2 class="entry-title"><%= post.title %></h2>
      </a>
      <p class="entry-description"><%= post.description || post.subtitle || strip_html(post.excerpt || post.content).slice(0, 180) %></p>
      <div class="entry-meta-row">
        <% if (post.categories && post.categories.data.length) { %>
        <span class="meta-chip"><%= sectionLabel(post.categories.data[0].name) %></span>
        <% } %>
      </div>
      <div class="entry-card-footer">
        <a class="entry-action" href="<%- url_for(post.path) %>"><%= __("section.open_entry") %></a>
      </div>
    </article>
    <% }) %>
  </div>
</section>
